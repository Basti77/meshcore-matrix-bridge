# --- Matrix ---
# Homeserver URL (no trailing slash)
MATRIX_HOMESERVER=https://matrix.notlegal.space

# Full MXID of the bridge bot
MATRIX_USER_ID=@meshcore:matrix.notlegal.space

# Access token (obtain via /login; see README)
MATRIX_ACCESS_TOKEN=syt_xxx

# Device ID returned by /login
MATRIX_DEVICE_ID=XXXXXXXXXX

# Comma-separated list of MXIDs allowed to control the bridge.
# The FIRST entry is invited to the auto-created DM control room.
MATRIX_ALLOWED_USERS=@klempi:matrix.notlegal.space

# Optional: pin a specific room id (skips auto-DM-create).
# MATRIX_ROOM_ID=!abcdef:matrix.notlegal.space

# --- MeshCore node ---
# Transport: "serial" or "ble"
MESHCORE_TRANSPORT=serial
# For serial: device path
MESHCORE_PORT=/dev/ttyACM0
MESHCORE_BAUDRATE=115200
# For BLE: set MESHCORE_TRANSPORT=ble and either:
#   MESHCORE_PORT=AA:BB:CC:DD:EE:FF   (exact BLE MAC) — preferred
# or
#   MESHCORE_PORT=scan
#   MESHCORE_BLE_NAME=MeshCore        (name filter)
# Note: only one BLE Central at a time — disconnect the phone before the
# bridge connects, or your phone will lose the node.
# MESHCORE_BLE_NAME=
MESHCORE_AUTO_RECONNECT=1

# --- Bridge behaviour ---
MESH_COMMAND_PREFIX=!mesh
MESH_AUTO_FETCH=1
# Set to 1 to forward channel RX automatically to the bridge room (noisy!).
MESH_RELAY_CHANNELS=0
# Comma-separated channel indexes to relay (empty = none). Use with MESH_RELAY_CHANNELS=1.
MESH_RELAY_CHANNEL_INDEXES=

# Persistent state (auto-created)
MESH_STATE_PATH=/home/klempi/.local/state/meshcore-matrix-bridge/state.json

LOG_LEVEL=INFO
